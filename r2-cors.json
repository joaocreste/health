{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://lumenhealth.io",
          "https://www.lumenhealth.io",
          "http://localhost:8788"
        ],
        "methods": ["PUT", "GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
